{
	"$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxfmt/configuration_schema.json",
	"printWidth": 100,
	"useTabs": true,
	"tabWidth": 4,
	"semi": true,
	"singleQuote": false,
	"trailingComma": "all",
	"bracketSpacing": true,
	"arrowParens": "always",
	"endOfLine": "lf",
	"sortImports": {
		"groups": ["builtin", "external", ["parent", "sibling", "index"], "unknown"]
	},
	"ignorePatterns": [
		"**/node_modules/**",
		"**/dist/**",
		"**/.turbo/**",
		"**/.cache/**",
		"**/test/fixtures/**",
		"**/*.min.js",
		"**/*.gen.ts"
	]
}
